# Book Tracker — Environment Variables
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env

# Library data directory (default: ./data/)
# Relative paths (./ or ../) are resolved from the project root.
# Absolute paths and ~/ paths are used as-is.
# Docker users: this is overridden in docker-compose.yml to /data.
BOOKTRACKER_LIBRARY_PATH=./data/
