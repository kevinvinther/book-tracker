# Book Tracker — Environment Variables
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env

# Library data directory (default: ./data/)
# Relative paths (./ or ../) are resolved from the project root.
# Tilde (~/) is expanded to the current user's home directory.
# Docker: the container runs as root, so ~/ expands to /root/ inside the container.
#   docker-compose.override.yml should mount your host directory to /root/book-tracker-data
#   so that ~/book-tracker-data resolves correctly on both sides.
BOOKTRACKER_LIBRARY_PATH=./data/
